# Local development environment variables
# Place this file at: d:\counselify\.env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_publishable_key

# Optional locally. In production Vercel will infer its own deployment URL, but keeping
# this set makes auth redirects explicit and predictable in development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
